      "types": "./dist/domains/onboarding/components/index.d.ts",
      "import": "./dist/domains/onboarding/components/index.js"
    },
    "./onboarding/hooks": {
      "types": "./dist/domains/onboarding/hooks/index.d.ts",
      "import": "./dist/domains/onboarding/hooks/index.js"
